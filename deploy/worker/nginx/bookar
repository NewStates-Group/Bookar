upstream flower_stream {
    server localhost:5555;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name flower.bookar.study;
    
    ssl_certificate /etc/letsencrypt/live/bookar.study/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/bookar.study/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
    
    location / {
        proxy_pass http://flower_stream;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }
}