upstream flower_stream {
    server localhost:5555;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name flower.bookar.study flower.localhost;
    
    ssl_certificate /etc/letsencrypt/live/bookar.study/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/bookar.study/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
    
    location / {
        proxy_pass http://flower_stream;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name bookar.study localhost;
    
    ssl_certificate /etc/letsencrypt/live/bookar.study/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/bookar.study/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        proxy_pass http://frontend_stream;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
    }

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location = /403.html {
        alias /home/ubuntu/Bookar/nginx/error_pages/403.html;
        internal;
    }

    location = /404.html {
        alias /home/ubuntu/Bookar/nginx/error_pages/404.html;
        internal;
    }

    location = /500.html {
        alias /home/ubuntu/Bookar/nginx/error_pages/500.html;
        internal;
    }

    location = /502.html {
        alias /home/ubuntu/Bookar/nginx/error_pages/502.html;
        internal;
    }

    error_page 403 /403.html;
    error_page 404 /404.html;
    error_page 500 /500.html;
    error_page 502 /502.html;

}